  puts "Style: #{style}"
  framed = Cockpit3000::Frames.wrap(content, style: style, palette: :neon, title: "#{style.to_s.upcase}")
  framed.each { |line| puts line }
  sleep 0.3
end

# Animated banner
puts
puts "Animated Banner:"
5.times do |frame|
  banner = Cockpit3000::Frames.banner("MAXIMUM PIZZAZZ", animated: true, frame_num: frame)
  banner.each { |line| puts line }
