print_header("DEMO 6: METRICS WITH MAXIMUM PIZZAZZ")

print_section("Real-time metrics tracking with sparkline graphs!")

work_items = (1..50).map do |i|
  {
    id: i,
    complexity: rand(1..10),
    data_size: rand(100..10000),
  }
end

work_items.with_progress(
  title: "🔬 ANALYZING DATA WITH STYLE 🔬",
  palette: :synthwave,
  style: :cyberpunk,
  rainbow_mode: true,
  spinner: :sparkle,
  celebration: :firework,
  glow: true,
  fps: 30
).each do |item|
  sleep_time = item[:complexity] * 0.01
  sleep(sleep_time)

  {
    latency_ms: (sleep_time * 1000).round(1) + rand(-5..5),
    throughput: (item[:data_size] / [sleep_time, 0.01].max).round(0),
    cpu_percent: rand(10..95),
    memory_mb: rand(50..500),
  }
end

