#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/cockpit3000"

# ═══════════════════════════════════════════════════════════════════════════════
#  PROGRESS INFO-OVERLOAD COCKPIT 3000 - MAXIMUM PIZZAZZ EDITION
# ═══════════════════════════════════════════════════════════════════════════════

def rainbow_print(text, delay = 0.02)
  text.each_char.with_index do |char, i|
    color = Cockpit3000::ANSI.rainbow_cycle(i * 0.1, Time.now.to_f, 2.0)
    print "#{color}#{char}\e[0m"
    $stdout.flush
    sleep(delay) if delay > 0
  end
  puts
end

def print_header(text)
  puts
  border = "═" * 74
  puts "\e[1;38;2;255;0;255m#{border}\e[0m"
  rainbow_print("  #{text}", 0.01)
  puts "\e[1;38;2;0;255;255m#{border}\e[0m"
  puts
  sleep 0.5
end

def print_section(text)
  puts
  puts "\e[38;2;255;200;100m▸ #{text}\e[0m"
  puts
  sleep 0.3
end

def clear_line
  print "\r\e[2K"
end

